{
  "version": "1.4.0",
  "name": "hive",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf ./public",
    "clean:deep": "git clean -x -d -f $(git rev-parse --show-toplevel)/**",
    "start": "dotnet watch -v -p ../Hive.Api run",
    "test": "vitest run -c vite.config.ts",
    "test:report": "vitest run -c vite.config.ts",
    "test:all": "run-p tsc test lint",
    "test:all:report": "run-p tsc test:report lint:report",
    "test:ui": "vitest --ui",
    "webstorm-integration": "vitest --watch --reporter=dot --reporter=json --outputFile=.vitest-result.json",
    "tsc": "tsc --noEmit",
    "lint": "run-p lint:src lint:test",
    "lint:fix": "run-p lint:src:fix lint:test:fix",
    "lint:report": "run-p lint:src lint:src:report lint:test lint:test:report",
    "lint:src": "eslint -c eslint.config.js src eslint.config.js",
    "lint:src:fix": "eslint -c eslint.config.js --fix src eslint.config.js",
    "lint:src:report": "eslint -c eslint.config.js -o reports/__lint__/eslint.json -f json src eslint.config.js",
    "lint:test": "eslint -c eslint.config.js test",
    "lint:test:fix": "eslint -c eslint.config.js --fix test",
    "lint:test:report": "eslint -c eslint.config.js -o reports/__lint__/eslint.test.json -f json test",
    "build": "run-s clean vite:build",
    "build:dev": "run-s tsc vite:dev",
    "build:dev:watch": "run-s vite:watch",
    "vite:build": "vite build --emptyOutDir",
    "vite:dev": "cross-env NODE_ENV=development vite build --manifest --sourcemap=true --mode development",
    "vite:watch": "cross-env NODE_ENV=development vite build --manifest  --sourcemap=true --mode development -w",
    "watch": "run-s clean vite:watch"
  },
  "lint-staged": {
    "*.{css,js,jsx,ts,tsx}": "eslint --fix -c eslint.config.js",
    "*.{md,scss}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@typescript-eslint/typescript-estree": "^8.58.0",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/eslint-plugin": "^1.6.14",
    "@vitest/ui": "4.1.2",
    "camelcase": "^9.0.0",
    "chalk": "^5.6.2",
    "eslint": "10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "fsevents": "^2.3.3",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@preact/preset-vite": "^2.10.5",
    "@preact/signals": "^2.9.0",
    "cross-env": "^10.1.0",
    "esbuild": "0.27.5",
    "lightningcss": "^1.32.0",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "preact": "^10.29.0",
    "rimraf": "^6.1.3",
    "vite": "8.0.5",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=20",
      "onFail": "warn"
    }
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@babel/core"
      ]
    },
    "overrides": {
      "semver": "7.7.4"
    }
  },
  "overrides": {},
  "packageManager": "pnpm@10.33.0+sha512.EFaLtKavtYyes2MNqQzJUWQXq+vT+rvmc58K55VyjaFJHp21pUTHatjrdXD1xLs9bGN7LLQb/c20f6gjyGSTGQ=="
}
